# Copie para `.env` na raiz (o Git ignora `.env`) ou cole no Easypanel → Environment.
#
# Easypanel: o host costuma ser o nome interno do serviço Postgres (ex.: profit_postgres).
# Use o driver postgresql+psycopg (ou postgres:// — a app normaliza).

DATABASE_URL=postgresql+psycopg://postgres:SUBSTITUIR_SENHA@profit_postgres:5432/profit?sslmode=disable

# Opcional (recomendado em contentores / Easypanel)
# PROFIT_APP_SQLALCHEMY_NULLPOOL=1
# PROFIT_APP_STORAGE_DIR=/data
